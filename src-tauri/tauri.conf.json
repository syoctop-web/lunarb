{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lunar",
  "version": "1.0.0",
  "identifier": "com.lunar.browser",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "windows": [
      {
        "title": "Lunar",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "shadow": true,
        "theme": "Dark",
        "backgroundColor": "#0d0d12"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; media-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https:; frame-src 'self' https:;"
    },
    "withGlobalTauri": true,
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Lunar Browser",
    "category": "Productivity",
    "shortDescription": "Lunar - A fast, beautiful, customizable browser",
    "longDescription": "Lunar is a lightweight, fast, and heavily customizable web browser built with Rust. It uses minimal system resources while providing a beautiful, modern browsing experience.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": false,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
